# Public site URL — used in metadata, canonical links, sitemap.
NEXT_PUBLIC_SITE_URL=https://miladkhatib.com

# Resend — drives /api/contact AND /api/studio/login (magic-link auth).
RESEND_API_KEY=

# Sender for magic-link + contact emails. Domain must be verified on Resend.
RESEND_FROM="Khatib Studio <noreply@miladkhatib.com>"

# Studio — magic-link signing secret. Generate with: openssl rand -hex 32
# Must be ≥32 chars. Rotating signs out every studio user.
STUDIO_SESSION_SECRET=

# Studio — comma-separated allowlist of authorised emails.
# Non-allowlisted addresses get silent success (anti-enumeration).
STUDIO_ALLOWLIST=milad@miladkhatib.com

# Plausible analytics (optional — Umami is loaded via Analytics.tsx separately).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=miladkhatib.com
