{
  "name": "khatib-website",
  "version": "0.2.0",
  "private": true,
  "description": "miladkhatib.com — bilingual EN/AR civilian engineering consultancy + Khatib Studio (auth-gated document workshop)",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npm run audit:civilian && next build",
    "start": "next start -p 3000",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:civilian": "node scripts/audit-civilian.mjs",
    "extract:publications": "node scripts/extract-publications.mjs",
    "extract:editorial": "node scripts/extract-editorial.mjs"
  },
  "dependencies": {
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8",
    "clsx": "2.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "20.14.10",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitest/coverage-v8": "2.1.4",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
